<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/taskListFragment">

    <fragment
        android:id="@+id/taskListFragment"
        android:name="com.hassan.tasknest.presentation.tasklist.TaskListFragment"
        android:label="Tasks">
        <action
            android:id="@+id/action_taskListFragment_to_addEditTaskBottomSheet"
            app:destination="@id/addEditTaskBottomSheet" />
        <action
            android:id="@+id/action_taskListFragment_to_taskDetailFragment"
            app:destination="@id/taskDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/taskDetailFragment"
        android:name="com.hassan.tasknest.presentation.taskdetail.TaskDetailFragment">
        <argument
            android:name="taskId"
            app:argType="long" />
        <action
            android:id="@+id/action_taskDetailFragment_to_addEditTaskBottomSheet"
            app:destination="@id/addEditTaskBottomSheet" />
    </fragment>

    <dialog
        android:id="@+id/addEditTaskBottomSheet"
        android:name="com.hassan.tasknest.presentation.addedittask.AddEditTaskBottomSheet">
        <argument
            android:name="taskId"
            app:argType="long"
            android:defaultValue="-1L" />
    </dialog>

</navigation>
