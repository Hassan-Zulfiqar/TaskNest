<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TaskNest" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <style name="Theme.TaskNest" parent="Base.Theme.TaskNest" />

    <style name="ThemeOverlay.TaskNest.FilterChip" parent="ThemeOverlay.Material3">
        <item name="chipStyle">@style/Widget.Material3.Chip.Filter</item>
    </style>

    <style name="ThemeOverlay.TaskNest.DatePickerSpinner" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:datePickerMode">spinner</item>
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="android:colorPrimary">@color/brand_primary</item>
        <item name="android:colorAccent">@color/brand_primary</item>
        <item name="colorAccent">@color/brand_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="ThemeOverlay.TaskNest.TimePickerSpinner" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:timePickerMode">spinner</item>
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="android:colorPrimary">@color/brand_primary</item>
        <item name="android:colorAccent">@color/brand_primary</item>
        <item name="colorAccent">@color/brand_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

</resources>